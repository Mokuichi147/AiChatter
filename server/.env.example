# LLMモデル設定 (LiteLLM)
LLM_MODEL=ollama_chat/glm-5:cloud
LLM_REASONING=          # reasoning_effort: true, none, low, medium, high (空=未指定)
LLM_SUB_MODEL=ollama_chat/glm-5:cloud
LLM_SUB_REASONING=      # reasoning_effort: true, none, low, medium, high (空=未指定)
OLLAMA_API_BASE=http://localhost:11434

# ASRモデル (mlx-audio)
ASR_MODEL=mlx-community/Qwen3-ASR-0.6B-8bit

# システムプロンプト
SYSTEM_PROMPT=あなたは役立つ日本語アシスタントです。簡潔に、2〜3文で答えてください。

# Web検索 (Tavily)
TAVILY_API_KEY=

# サブエージェント設定
SUBAGENT_ENABLED=true
SUBAGENT_MAX_ROUNDS=8
SUBAGENT_TIMEOUT_SEC=500
SUBAGENT_MCP_TOOL_DENYLIST=
SUBAGENT_RESULT_MAX_CHARS=4000

# サーバー設定
HOST=0.0.0.0
PORT=8765
