# Ollama LLMモデル設定
LLM_MODEL=granite4:micro-h
OLLAMA_BASE_URL=http://localhost:11434/v1

# Whisper ASRモデルサイズ (tiny, base, small, medium, large-v2, large-v3)
WHISPER_MODEL_SIZE=base

# piper-tts日本語モデルパス (server/models/ 以下に配置)
PIPER_MODEL_PATH=models/tts.onnx

# システムプロンプト
SYSTEM_PROMPT=あなたは役立つ日本語アシスタントです。簡潔に、2〜3文で答えてください。

# サーバー設定
HOST=0.0.0.0
PORT=8765
