# LLMモデル設定 (OpenAI Responses API)
LLM_MODEL=gpt-4o
LLM_API_KEY=
LLM_BASE_URL=http://localhost:11434/v1
LLM_REASONING=          # reasoning effort: low, medium, high (空=未指定)
LLM_SUB_MODEL=
LLM_SUB_API_KEY=        # 空ならLLM_API_KEYを使用
LLM_SUB_BASE_URL=       # 空ならLLM_BASE_URLを使用
LLM_SUB_REASONING=      # 空ならLLM_REASONINGを使用

# ASRモデル (mlx-audio)
ASR_MODEL=mlx-community/Qwen3-ASR-0.6B-8bit

# システムプロンプト
SYSTEM_PROMPT=あなたは役立つ日本語アシスタントです。簡潔に、2〜3文で答えてください。

# Web検索 (Tavily)
TAVILY_API_KEY=

# サブエージェント設定
SUBAGENT_ENABLED=true
SUBAGENT_MAX_ROUNDS=8
SUBAGENT_TIMEOUT_SEC=500
SUBAGENT_MCP_TOOL_DENYLIST=
SUBAGENT_RESULT_MAX_CHARS=4000

# サーバー設定
HOST=0.0.0.0
PORT=8765
